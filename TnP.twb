                <zone forceUpdate='true' h='12750' id='33' type-v2='text' w='17100' x='25000' y='86250'>
                  <formatted-text>
                    <run bold='true' fontcolor='#000000'>Students with internship experience and higher employability scores demonstrated better placement success, emphasizing the value of practical exposure beyond academics.</run>
                  </formatted-text>
